# Drug Pricing Demo - Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/

# Grove Gateway API Key (for OpenAI via Grove endpoint)
GROVE_API_KEY=sk-...

# Grove Gateway Endpoint (OpenAI)
GROVE_ENDPOINT=https://grove-gateway-prod.azure-api.net/grove-foundry-prod/openai/v1/chat/completions

# OpenAI Model (via Grove)
OPENAI_MODEL=gpt-5.2

# Voyage AI API Key (for embeddings via MongoDB AI endpoint)
VOYAGE_API_KEY=pa-...

# MongoDB AI Endpoint (Voyage embeddings)
VOYAGE_ENDPOINT=https://ai.mongodb.com/v1/embeddings

# Voyage Model
VOYAGE_MODEL=voyage-4-large

# Optional: Database name (default: pricing_demo)
DB_NAME=pricing_demo

# Optional: Customer ID for filtering
CUSTOMER_ID=acmehealth123

